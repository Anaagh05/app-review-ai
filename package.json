{
  "name": "app-review-ai",
  "version": "0.1.0",
  "description": "Automated weekly pulse — turns Groww app reviews into themed insight reports, delivered via MCP servers",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "mcp-servers/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "pulse": "tsx src/cli.ts",
    "pulse:run": "tsx src/cli.ts run",
    "pulse:status": "tsx src/cli.ts status",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "franc-min": "^6.2.0",
    "groq-sdk": "^1.2.1",
    "umap-js": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
