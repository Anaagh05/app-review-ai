# ==============================================================================
# Weekly Product Review Pulse - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# Only PULSE_LLM_API_KEY is strictly required. All other variables have defaults.

# ------------------------------------------------------------------------------
# App & Product Identity
# ------------------------------------------------------------------------------
# PULSE_PRODUCT=groww
# PULSE_APPSTORE_APP_ID=1404684361
# PULSE_APPSTORE_COUNTRY=in
# PULSE_PLAYSTORE_APP_ID=com.nextbillion.groww
# PULSE_PLAYSTORE_COUNTRY=in
# PULSE_PLAYSTORE_LANG=en

# ------------------------------------------------------------------------------
# Ingestion & Safety
# ------------------------------------------------------------------------------
# PULSE_REVIEW_WINDOW_WEEKS=10
# PULSE_SAFETY_MAX_REVIEWS=2000
# PULSE_SAFETY_PII_SCRUB_ENABLED=true

# ------------------------------------------------------------------------------
# LLM (Groq) Configuration
# ------------------------------------------------------------------------------
# YOUR GROQ API KEY GOES HERE (Free tier works!)
PULSE_LLM_API_KEY=your_groq_api_key_here

# PULSE_LLM_MODEL=llama-3.3-70b-versatile
# PULSE_LLM_MAX_TOTAL_TOKENS_PER_RUN=100000
# PULSE_LLM_TIMEOUT_MS=60000

# (Note: Max tokens per minute and requests per minute limits are enforced 
# by the internal RateLimiter according to Groq's free tier: 12K TPM / 30 RPM)

# ------------------------------------------------------------------------------
# Clustering (UMAP & HDBSCAN)
# ------------------------------------------------------------------------------
# PULSE_UMAP_N_COMPONENTS=5
# PULSE_UMAP_METRIC=cosine
# PULSE_UMAP_SEED=42
# PULSE_HDBSCAN_MIN_CLUSTER_SIZE=10
# PULSE_TOP_K_CLUSTERS=5

# ------------------------------------------------------------------------------
# Delivery (Google Docs & Gmail via MCP)
# ------------------------------------------------------------------------------
# "draft" (default) or "send"
# PULSE_DELIVERY_MODE=draft
# PULSE_DELIVERY_DOC_TITLE="Weekly Review Pulse — Groww"
# PULSE_DELIVERY_EMAIL_RECIPIENTS=team@example.com,manager@example.com
# PULSE_DELIVERY_EMAIL_SUBJECT_TEMPLATE="Groww Review Pulse — Week {ISO_WEEK}"

# Google Workspace MCP server (Railway deployment)
# The server exposes:
#   POST /append_to_doc       → { doc_id, content }   (plain text only, no formatting params)
#   POST /create_email_draft  → { to, subject, body }
GOOGLE_MCP_URL=https://mcp-server-production-1edb.up.railway.app

# The Google Doc ID to append weekly pulse reports to.
# Find this in your Doc URL: https://docs.google.com/document/d/<DOC_ID>/edit
GOOGLE_DOC_ID=YOUR_GOOGLE_DOC_ID_HERE

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
# PULSE_DB_PATH=./data/pulse.db
